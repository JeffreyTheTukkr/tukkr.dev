{
    "name": "tukkr",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig tsconfig.json --watch",
        "lint": "prettier --check . '!pnpm-lock.yaml' && eslint .",
        "format": "prettier --write . '!pnpm-lock.yaml'",
        "prepare": "husky"
    },
    "dependencies": {
        "gray-matter": "^4.0.3",
        "mdsvex": "^0.12.7"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/kit": "^2.56.1",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@types/node": "^25.5.2",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.17.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.1",
        "sass": "^1.99.0",
        "svelte": "^5.55.1",
        "svelte-check": "^4.4.6",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.5"
    },
    "lint-staged": {
        "*": [
            "prettier --write . '!pnpm-lock.yaml'"
        ]
    },
    "type": "module"
}
